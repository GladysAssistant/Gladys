# ── Stage 1 : compilation du frontend ───────────────────────────────
FROM node:22-slim AS front-builder

WORKDIR /app/front

# Installation des dépendances front en premier pour bénéficier du cache Docker
COPY front/package*.json ./
RUN npm ci

# Copie des sources et build (génère /app/front/build/)
COPY front/ ./
RUN NODE_OPTIONS=--openssl-legacy-provider npm run build

# ── Stage 2 : serveur de production ─────────────────────────────────
FROM node:22-slim

# Dépendances système (même liste que le Dockerfile officiel)
RUN apt-get update && apt-get install -y --no-install-recommends \
        tzdata \
        nmap \
        ffmpeg \
        sqlite3 \
        openssl \
        gzip \
        udev \
        bluez \
        build-essential \
        python3 \
        python3-pip \
        git \
        libffi-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /src/server

# Installation des dépendances serveur (avec cache Docker sur le package.json)
COPY server/package*.json ./
RUN npm ci --unsafe-perm --production \
    && npm cache clean --force

# Nettoyage des outils de compilation (réduit la taille de l'image finale)
RUN apt-get autoremove -y build-essential python3 python3-pip git libffi-dev \
    && apt-get purge -y --auto-remove \
    && rm -rf /var/lib/apt/lists/*

# Copie du code serveur
COPY server/ ./

# Copie du front compilé depuis le stage 1
COPY --from=front-builder /app/front/build ./static

ENV NODE_ENV=production
ENV SERVER_PORT=1443

EXPOSE 1443

CMD ["node", "index.js"]
